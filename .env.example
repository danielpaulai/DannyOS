# Use the "URI" from Database settings (direct connection) for Prisma from your laptop:
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.hgtsozokxygzpubqbtjy.supabase.co:5432/postgres"
#
# Optional: if you switch DATABASE_URL to the Supabase pooler (port 6543) for serverless,
# add a direct connection for Prisma migrations (same host as above, direct port 5432):
# DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.hgtsozokxygzpubqbtjy.supabase.co:5432/postgres"

# Optional — only if you add @supabase/supabase-js in the app later:
# NEXT_PUBLIC_SUPABASE_URL="https://hgtsozokxygzpubqbtjy.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="paste-anon-key-from-project-api-settings"

